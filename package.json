{
  "name": "reporting-engine",
  "version": "1.0.0",
  "description": "Enterprise-grade reporting platform with multi-source data integration",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:frontend": "turbo run dev --filter=@reporting-engine/frontend",
    "dev:backend": "turbo run dev --filter=@reporting-engine/backend",
    "build": "turbo run build",
    "build:frontend": "turbo run build --filter=@reporting-engine/frontend",
    "build:backend": "turbo run build --filter=@reporting-engine/backend",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "turbo run db:migrate --filter=@reporting-engine/backend",
    "db:seed": "turbo run db:seed --filter=@reporting-engine/backend",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "clean": "turbo run clean && rm -rf node_modules dist .next .turbo",
    "generate:types": "turbo run generate:types"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.48.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "turbo": "^1.10.0",
    "typescript": "^5.2.0"
  },
  "packageManager": "npm@10.0.0"
}
